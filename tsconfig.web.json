{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"lib": ["ES2024", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"types": ["vite/client"],
		"paths": {
			"@renderer/*": ["./src/renderer/src/*"],
			"@main/*": ["./src/main/*"],
			"@shared/*": ["./src/shared/*"]
		}
	},
	"include": ["src/renderer/**/*", "src/shared/**/*"]
}

{
	"name": "jubby",
	"version": "0.1.8",
	"private": true,
	"description": "Task manager with retro terminal aesthetic",
	"author": {
		"name": "lobomfz",
		"email": "lobomfz@protonmail.com"
	},
	"homepage": "https://github.com/juicerq/jubby",
	"repository": {
		"type": "git",
		"url": "https://github.com/juicerq/jubby.git"
	},
	"productName": "Jubby",
	"appId": "io.github.juicerq.jubby",
	"type": "module",
	"main": "./out/main/index.js",
	"engines": {
		"bun": ">=1.3.0"
	},
	"scripts": {
		"dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
		"build": "electron-vite build",
		"preview": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
		"dist": "electron-vite build && electron-builder --publish never",
		"dist:linux": "electron-vite build && electron-builder --linux --publish never",
		"dist:win": "electron-vite build && electron-builder --win --publish never",
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "lobomfz-check",
		"check:fix": "lobomfz-check --fix",
		"prepare": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "bun run check"
	},
	"dependencies": {
		"@ai-sdk/groq": "^3.0.38",
		"@fontsource/pixelify-sans": "^5.2.7",
		"@orpc/client": "^1.14.0",
		"@orpc/server": "^1.14.0",
		"@orpc/tanstack-query": "^1.14.0",
		"@tanstack/react-query": "^5.99.2",
		"@tanstack/react-router": "^1.168.23",
		"ai": "^6.0.174",
		"arktype": "^2.2.0",
		"electron-updater": "^6.8.3",
		"lucide-react": "^1.14.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-markdown": "^10.1.0",
		"rehype-highlight": "^7.0.2",
		"remark-gfm": "^4.0.1",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@lobomfz/check": "^0.1.10",
		"@tailwindcss/vite": "^4.2.4",
		"@tanstack/router-plugin": "^1.167.22",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.0.0",
		"bun-types": "^1.3.13",
		"electron": "^33.0.0",
		"electron-builder": "^25.1.8",
		"electron-vite": "^4.0.0",
		"oxlint": "^1.62.0",
		"oxlint-tsgolint": "^0.22.1",
		"simple-git-hooks": "^2.13.1",
		"tailwindcss": "^4.2.4",
		"typescript": "^5.9.0",
		"vite": "^6.0.0",
		"vitest": "^4.1.5"
	}
}
